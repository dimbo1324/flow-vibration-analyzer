{
    "name": "iva-web-frontend",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src --max-warnings 0",
