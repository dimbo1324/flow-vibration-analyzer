# Исключения для Docker — не копировать в образ локальные артефакты,
# кеши и виртуальное окружение. Уменьшает контекст сборки и предотвращает
# утечку локальных данных пользователя в образ.

# Виртуальные окружения Python
.venv/
venv/
env/
ENV/

# Директории сборки и дистрибутива
build/
dist/
out/
reports/

# Кеши инструментов
.pytest_cache/
.mypy_cache/
.ruff_cache/
__pycache__/
*.pyc
*.pyo
*.pyd

# Пакетные артефакты
*.egg-info/
.eggs/

# Покрытие
.coverage
.coverage.*
htmlcov/

# Git-история (не нужна внутри образа)
.git/
.gitignore

# CI/CD и IDE
.github/
.idea/
.vscode/

# Данные результатов и отчёты (генерируются во время работы)
data/results/

# Frontend build artefacts — не нужны в Python-образах
web/frontend/node_modules/
web/frontend/dist/
web/frontend/.vite/
web/frontend/coverage/
